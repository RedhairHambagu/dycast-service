# Dycast 认证配置示例
# 复制此文件为 .env 并填入实际值
#
# ⚠️  注意：这些变量在构建和运行时都需要设置！

# ========================================
# 认证配置（必需）
# ========================================

# 管理员密码盐值（16 字节随机值）
# 使用 scripts/generate-hash.js 生成
VITE_ADMIN_SALT=your_salt_here

# 管理员密码哈希值
# 使用 scripts/generate-hash.js 生成
VITE_ADMIN_HASH=your_hash_here

# 登录页面 URL 路径（可选，默认为 /login）
# 可以是任意路径，如：/admin, /secure, /login
VITE_LOGIN_URL=/login

# ========================================
# 可选配置
# ========================================

# 默认房间号（有值时自动填充到房间号输入框）
VITE_DEFAULT_ROOM=

# ========================================
# 生成步骤
# ========================================
# 1. 运行：node scripts/generate-hash.js <your_password>
# 2. 将生成的 SALT 和 HASH 值复制到上面
# 3. 根据需要修改 VITE_LOGIN_URL
# 4. 重命名此文件为 .env

# ========================================
# 使用说明
# ========================================
# 本地开发：
# - 复制此文件为 .env 文件
# - npm run dev 会自动读取 .env 文件
#
# Docker 部署：
# - 环境变量通过 docker-compose.yml 的 environment 字段传递
# - 或使用 docker run -e 参数传递
# - 或使用 --env-file 指定环境变量文件
# - 示例：docker compose --env-file .env up -d --build
